// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  usercode  String   @unique
  email     String?  @unique
  password  String
  fullName  String?
  role      Role     @default(USER)
  
  // Thông tin phòng ban và chức vụ
  departmentId Int?
  positionId   Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  position     Position?   @relation(fields: [positionId], references: [id])

  // Khóa học giảng dạy
  courses     Course[]

refreshTokens    RefreshToken[]
  progresses     LearningProgress[]
  enrollments    Enrollment[]
  academyEnrollments AcademyEnrollment[]
  classEnrollments ClassEnrollment[]
  videoLikes     VideoLike[]

  createdAt DateTime @default(now())

  @@map("users")
}

// Phòng ban
model Department {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("departments")
}

// Chức vụ
model Position {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("positions")
}

// Cấu hình hệ thống
model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique
  configValue String
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

enum Role {
  USER
  ADMIN
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// Danh mục khóa học (có cấu trúc phân cấp cha-con)
model CourseCategory {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  // Quan hệ với học viện (bắt buộc)
  academyId   Int
  academy    Academy   @relation(fields: [academyId], references: [id])
  
// Danh mục cha (tự tham chiếu - cho phép tạo danh mục con)
  parentId    Int?
  parent     CourseCategory? @relation("CategoryChildren", fields: [parentId], references: [id])
  children   CourseCategory[] @relation("CategoryChildren")
  
  // Khóa học thuộc danh mục này
  courses     Course[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, academyId])
  @@index([academyId])
  @@index([parentId])
  @@map("course_categories")
}

// Quy tắc khóa học
model CourseRule {
  id                    Int      @id @default(autoincrement())
  antiFastForward       Boolean  @default(false)  // Chống tua nhanh
  lockSpeed1x           Boolean  @default(false)  // Khóa tốc độ 1x
  showWatermark         Boolean  @default(false)  // Hiển thị watermark
  blockDownload         Boolean  @default(false)  // Chặn tải xuống
  requireFullCompletion Boolean  @default(false)  // Yêu cầu hoàn thành 100% video

  course                Course?  @relation(fields: [courseId], references: [id])
  courseId              Int?      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_rules")
}

model Course {
  id              Int      @id @default(autoincrement())
  
  // Tiêu đề đa ngôn ngữ
  title_vi         String?
  title_en         String?
  title_zh         String?
  
  // Mô tả đa ngôn ngữ
  description_vi   String?
  description_en   String?
  description_zh  String?
  
  // Ảnh bìa
  coverImage       String?
  
  // Trạng thái công khai
  isPublic        Boolean  @default(false)
  
  // Điểm số đánh giá
  rating          Float    @default(0)
  
  // Ngôn ngữ đào tạo
  language        String?  // e.g., "vi", "en", "zh"
  
  // Nhóm đối tượng đào tạo
  targetAudience  String?
  
  // Lợi ích khóa học (JSON array)
  benefits       Json?
  
  // Thẻ khóa học (JSON array)
  tags           Json?
  
  // Quan hệ
  academy        Academy?          @relation(fields: [academyId], references: [id])
  academyId      Int?
  
  category      CourseCategory?    @relation(fields: [categoryId], references: [id])
  categoryId    Int?
  
  instructor    User?             @relation(fields: [instructorId], references: [id])
  instructorId Int?

  lessons       Lesson[]
  enrollments  Enrollment[]
  courseVideos CourseVideo[]
  rule         CourseRule?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courses")
}

// Liên kết Course với Video (nhiều video cho 1 khóa học)
model CourseVideo {
  id        Int   @id @default(autoincrement())

  courseId  Int
  videoId   Int

  course    Course @relation(fields: [courseId], references: [id])
  video     Video  @relation(fields: [videoId], references: [id])

  order     Int    @default(0)  // Thứ tự video

  createdAt DateTime @default(now())

  @@unique([courseId, videoId])
  @@map("course_videos")
}

model Lesson {
  id        Int     @id @default(autoincrement())
  title     String
  order     Int

  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id])

  videoId   Int?
  video    Video?  @relation("LessonOwnsVideo", fields: [videoId], references: [id])
  videoForLesson Video? @relation("VideoOwnsLesson")
  progresses LearningProgress[]

  @@map("lessons")
}

enum VideoStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Video {
  id        Int    @id @default(autoincrement())

  lessonId  Int?   @unique
  lesson    Lesson? @relation("VideoOwnsLesson", fields: [lessonId], references: [id])
  ownedByLessons Lesson[] @relation("LessonOwnsVideo")

  bucket    String
  path      String   // Original video source path (e.g., uploads/uuid.mp4)
  hlsPath   String?  // HLS output path (e.g., hls/25)
  
  name      String?  // Video name/label
  thumbnailUrl String?  // Thumbnail image URL

  duration  Int?
  status    VideoStatus @default(PROCESSING)
  progress  Int       @default(0)  // Processing progress 0-100%

  // Khóa học có video này
  courseVideos CourseVideo[]
  likes        VideoLike[]

  @@map("videos")
}

// Like video của người dùng
model VideoLike {
  id        Int   @id @default(autoincrement())

  userId    Int
  videoId   Int

  user      User  @relation(fields: [userId], references: [id])
  video     Video @relation(fields: [videoId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@map("video_likes")
}

model Enrollment {
  id        Int   @id @default(autoincrement())

  userId    Int
  courseId  Int

  user      User   @relation(fields: [userId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LearningProgress {
  id        Int @id @default(autoincrement())

  userId    Int
  lessonId  Int

  user      User   @relation(fields: [userId], references: [id])
  lesson    Lesson @relation(fields: [lessonId], references: [id])

  watchedSeconds Int @default(0)
  completed      Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// Học viện (Academy)
model Academy {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  isPublic    Boolean  @default(false) // true = all users can access, false = only assigned users
  
  // Khóa học thuộc học viện
  courses     Course[]
  
  enrollments AcademyEnrollment[]
  
  // Lớp học và kế hoạch đào tạo thuộc học viện
  trainingClasses TrainingClass[]
  trainingPlans  TrainingPlan[]
  
  // Danh mục câu hỏi thuộc học viện
  questionCategories QuestionCategory[]

  // Danh mục khóa học thuộc học viện
  courseCategories CourseCategory[]

  // Kỳ thi thuộc học viện
  examSessions ExamSession[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("academies")
}

// Liên kết User với Academy (khi isPublic = false)
model AcademyEnrollment {
  id        Int   @id @default(autoincrement())

  userId    Int
  academyId Int

  user      User   @relation(fields: [userId], references: [id])
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, academyId])
  @@map("academy_enrollments")
}

// ==================== TRAINING PLAN MODELS ====================

// Lớp học (Training Class)
model TrainingClass {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  description_vi   String?
  description_en   String?
  description_zh  String?
  
  // Nội dung đào tạo
  content_vi       String?
  content_en       String?
  content_zh      String?
  
  // Mục tiêu đào tạo
  objectives_vi    String?
  objectives_en    String?
  objectives_zh   String?
  
  // Đối tượng tham gia
  targetAudience  String?
  
  // Thời gian bắt đầu và kết thúc
  startDate        DateTime?
  endDate          DateTime?
  
  // Quan hệ
  academyId   Int?
  academy    Academy?  @relation(fields: [academyId], references: [id])
  
  // Giảng viên phụ trách
  lecturerId  Int?
  lecturer   Lecturer? @relation(fields: [lecturerId], references: [id])
  
  // Kế hoạch đào tạo thuộc lớp này
  trainingPlans TrainingPlan[]
  
  // Học viên trong lớp
  enrollments ClassEnrollment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("training_classes")
}

// Học viên trong lớp học
model ClassEnrollment {
  id        Int   @id @default(autoincrement())

  userId    Int
  classId   Int

  user      User   @relation(fields: [userId], references: [id])
  class     TrainingClass @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, classId])
  @@map("class_enrollments")
}

// Kế hoạch đào tạo (Training Plan)
model TrainingPlan {
  id              Int      @id @default(autoincrement())
  
  // Tiêu đề đa ngôn ngữ
  title_vi         String?
  title_en         String?
  title_zh         String?
  
  // Mô tả đa ngôn ngữ
  description_vi   String?
  description_en  String?
  description_zh  String?
  
  // Ảnh bìa
  coverImage       String?
  
  // Thời gian bắt đầu và kết thúc
  startDate        DateTime?
  endDate          DateTime?
  
// Trạng thái (DRAFT, ACTIVE, COMPLETED, CANCELLED)
  status          String          @default("DRAFT")
  
  // Quan hệ
  academy        Academy?          @relation(fields: [academyId], references: [id])
  academyId      Int?
  
  trainingClass  TrainingClass?    @relation(fields: [trainingClassId], references: [id])
  trainingClassId Int?
  
  // Tài nguyên đào tạo (khóa học, kỳ thi, tài liệu)
  resources       TrainingResource[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("training_plans")
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

// Tài nguyên của kế hoạch đào tạo
model TrainingResource {
  id              Int      @id @default(autoincrement())
  
// Loại tài nguyên (COURSE, EXAM, DOCUMENT)
  type            String
  
  // ID tham chiếu (courseId, examId, documentId)
  refId           Int
  
  // Tên tài nguyên
  title_vi        String?
  title_en        String?
  title_zh        String?
  
  // Thứ tự hiển thị
  order           Int      @default(0)
  
  // Kế hoạch cha
  trainingPlan    TrainingPlan @relation(fields: [trainingPlanId], references: [id])
  trainingPlanId Int
  
  createdAt DateTime @default(now())

  @@map("training_resources")
}

enum TrainingResourceType {
  COURSE
  EXAM
  DOCUMENT
}

// Loại giảng viên
enum LecturerType {
  INTERNAL  // Nội bộ
  EXTERNAL  // Bên ngoài
}

// Giới tính
enum LecturerGender {
  MALE
  FEMALE
}

// Giảng viên (Lecturer)
model Lecturer {
  id        Int          @id @default(autoincrement())
  code      String       @unique  // Mã giảng viên
  name      String?      // Tên giảng viên
  type      LecturerType @default(INTERNAL)  // Loại giảng viên
  gender   LecturerGender @default(MALE)  // Giới tính
  phone    String?      // Số điện thoại
  email    String?      // Email (chỉ cho giảng viên bên ngoài)
  address  String?      // Địa chỉ (chỉ cho giảng viên bên ngoài)
  
  // Lớp học phụ trách
  trainingClasses TrainingClass[]
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("lecturers")
}

// ==================== QUESTION BANK MODELS ====================
// Question types: FILL_BLANK, SINGLE_CHOICE, MULTIPLE_CHOICE, TRUE_FALSE
// Question difficulty: EASY, MEDIUM, HARD

// Danh mục câu hỏi (Question Category)
model QuestionCategory {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  description String?
  
  // Quan hệ với học viện (bắt buộc)
  academyId   Int
  academy    Academy   @relation(fields: [academyId], references: [id])
  
  // Danh sách câu hỏi trong danh mục
  questions   Question[]

  // Kỳ thi liên kết đề (tạo từ danh mục)
  examSessions ExamSession[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name_vi, academyId])
  @@map("question_categories")
}

// Kỳ thi (Exam Session)
model ExamSession {
  id Int @id @default(autoincrement())

  // Tên kỳ thi đa ngôn ngữ
  name_vi String
  name_en String?
  name_zh String?

  // Quan hệ học viện và đề thi liên kết (danh mục câu hỏi)
  academyId Int
  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  paperCategoryId Int
  paperCategory QuestionCategory @relation(fields: [paperCategoryId], references: [id], onDelete: Cascade)

  // Thời gian thi
  startAt DateTime
  endAt DateTime

  // Quy tắc thi
  attemptLimit Int @default(1)
  passingScore Int @default(70)
  durationMinutes Int @default(60)

  // Cài đặt chống gian lận
  antiCheat Boolean @default(true)
  requireFullscreen Boolean @default(true)
  detectTabSwitch Boolean @default(true)
  shuffleQuestions Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([paperCategoryId])
  @@map("exam_sessions")
}

// Câu hỏi (Question)
model Question {
  id              Int      @id @default(autoincrement())
  
  // Nội dung câu hỏi đa ngôn ngữ
  question_vi    String?
  question_en    String?
  question_zh    String?
  
  // Loại câu hỏi (stored as String)
  type           String    @default("SINGLE_CHOICE")
  
  // Độ khó (stored as String)
  difficulty     String    @default("MEDIUM")
  
  // Câu trả lời đúng (JSON - có thể array cho MULTIPLE_CHOICE)
  correctAnswer  Json
  
  // Quan hệ với danh mục
  categoryId     Int
  category       QuestionCategory  @relation(fields: [categoryId], references: [id])
  
  // Các lựa chọn (cho câu hỏi chọn)
  options        QuestionOption[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("questions")
}

// Lựa chọn câu trả lời (Question Option)
model QuestionOption {
  id          Int      @id @default(autoincrement())
  
  // Nội dung lựa chọn đa ngôn ngữ
  option_vi   String?
  option_en   String?
  option_zh   String?
  
  // Thứ tự hiển thị
  order       Int      @default(0)
  
  // Câu hỏi cha
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@map("question_options")
}

// ==================== DOCUMENT MODELS ====================

// Tài liệu (Document)
model Document {
  id        Int      @id @default(autoincrement())
  name      String?
  type      String   // FILE_TYPE: xlsx, docx, pdf, pptx
  size      Int      // Size in bytes
  bucket    String
  path      String   // Path in MinIO
  
  createdAt DateTime @default(now())

  @@map("documents")
}

// Thẻ khóa học (Course Tag)
model CourseTag {
  id          Int      @id @default(autoincrement())
  name_vi     String
  name_en     String?
  name_zh     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("course_tags")
}
