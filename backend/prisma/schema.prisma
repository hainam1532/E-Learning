// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  usercode  String   @unique
  email     String?  @unique
  password  String
  fullName  String?
  role      Role     @default(USER)
  
  // Thông tin phòng ban và chức vụ
  departmentId Int?
  positionId   Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  position     Position?   @relation(fields: [positionId], references: [id])

  // Khóa học giảng dạy
  courses     Course[]

refreshTokens    RefreshToken[]
  progresses     LearningProgress[]
  enrollments    Enrollment[]
  academyEnrollments AcademyEnrollment[]

  createdAt DateTime @default(now())

  @@map("users")
}

// Phòng ban
model Department {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("departments")
}

// Chức vụ
model Position {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("positions")
}

// Cấu hình hệ thống
model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique
  configValue String
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

enum Role {
  USER
  ADMIN
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// Danh mục khóa học
model CourseCategory {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  
  courses     Course[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("course_categories")
}

// Quy tắc khóa học
model CourseRule {
  id                    Int      @id @default(autoincrement())
  antiFastForward       Boolean  @default(false)  // Chống tua nhanh
  lockSpeed1x           Boolean  @default(false)  // Khóa tốc độ 1x
  showWatermark         Boolean  @default(false)  // Hiển thị watermark
  blockDownload         Boolean  @default(false)  // Chặn tải xuống
  requireFullCompletion Boolean  @default(false)  // Yêu cầu hoàn thành 100% video

  course                Course?  @relation(fields: [courseId], references: [id])
  courseId              Int?      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_rules")
}

model Course {
  id              Int      @id @default(autoincrement())
  
  // Tiêu đề đa ngôn ngữ
  title_vi         String?
  title_en         String?
  title_zh         String?
  
  // Mô tả đa ngôn ngữ
  description_vi   String?
  description_en   String?
  description_zh  String?
  
  // Ảnh bìa
  coverImage       String?
  
  // Trạng thái công khai
  isPublic        Boolean  @default(false)
  
  // Điểm số đánh giá
  rating          Float    @default(0)
  
  // Ngôn ngữ đào tạo
  language        String?  // e.g., "vi", "en", "zh"
  
  // Nhóm đối tượng đào tạo
  targetAudience  String?
  
  // Lợi ích khóa học (JSON array)
  benefits       Json?
  
  // Thẻ khóa học (JSON array)
  tags           Json?
  
  // Quan hệ
  academy        Academy?          @relation(fields: [academyId], references: [id])
  academyId      Int?
  
  category      CourseCategory?    @relation(fields: [categoryId], references: [id])
  categoryId    Int?
  
  instructor    User?             @relation(fields: [instructorId], references: [id])
  instructorId Int?

  lessons       Lesson[]
  enrollments  Enrollment[]
  courseVideos CourseVideo[]
  rule         CourseRule?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courses")
}

// Liên kết Course với Video (nhiều video cho 1 khóa học)
model CourseVideo {
  id        Int   @id @default(autoincrement())

  courseId  Int
  videoId   Int

  course    Course @relation(fields: [courseId], references: [id])
  video     Video  @relation(fields: [videoId], references: [id])

  order     Int    @default(0)  // Thứ tự video

  createdAt DateTime @default(now())

  @@unique([courseId, videoId])
  @@map("course_videos")
}

model Lesson {
  id        Int     @id @default(autoincrement())
  title     String
  order     Int

  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id])

  video     Video?
  progresses LearningProgress[]

  @@map("lessons")
}

enum VideoStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Video {
  id        Int    @id @default(autoincrement())

  lessonId  Int?   @unique
  lesson    Lesson? @relation(fields: [lessonId], references: [id])

  bucket    String
  path      String   // Original video source path (e.g., uploads/uuid.mp4)
  hlsPath   String?  // HLS output path (e.g., hls/25)
  
  name      String?  // Video name/label
  thumbnailUrl String?  // Thumbnail image URL

  duration  Int?
  status    VideoStatus @default(PROCESSING)
  progress  Int       @default(0)  // Processing progress 0-100%

  // Khóa học có video này
  courseVideos CourseVideo[]

  @@map("videos")
}

model Enrollment {
  id        Int   @id @default(autoincrement())

  userId    Int
  courseId  Int

  user      User   @relation(fields: [userId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LearningProgress {
  id        Int @id @default(autoincrement())

  userId    Int
  lessonId  Int

  user      User   @relation(fields: [userId], references: [id])
  lesson    Lesson @relation(fields: [lessonId], references: [id])

  watchedSeconds Int @default(0)
  completed      Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// Học viện (Academy)
model Academy {
  id          Int      @id @default(autoincrement())
  name_vi     String?
  name_en     String?
  name_zh     String?
  code        String   @unique
  description String?
  isPublic    Boolean  @default(false) // true = all users can access, false = only assigned users
  
  // Khóa học thuộc học viện
  courses     Course[]
  
  enrollments AcademyEnrollment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("academies")
}

// Liên kết User với Academy (khi isPublic = false)
model AcademyEnrollment {
  id        Int   @id @default(autoincrement())

  userId    Int
  academyId Int

  user      User   @relation(fields: [userId], references: [id])
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, academyId])
  @@map("academy_enrollments")
}
